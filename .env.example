APP_NAME=TruthShield
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=truth_shield
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=
TRUTHSHIELD_STATUS_CACHE_STORE=redis
FRONTEND_URL=http://127.0.0.1:15173

# ECPay staging defaults. Replace these only on the backend server.
ECPAY_CHECKOUT_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_MERCHANT_ID=<ECPAY_STAGING_MERCHANT_ID>
ECPAY_HASH_KEY=<ECPAY_STAGING_HASH_KEY>
ECPAY_HASH_IV=<ECPAY_STAGING_HASH_IV>
ECPAY_TRADE_PREFIX=TSD
ECPAY_API_BASE_URL=http://127.0.0.1:18080
ECPAY_WEB_BASE_URL=http://127.0.0.1:15173
TRUTHSHIELD_DONATION_AMOUNTS=100,300,500,1000,2000,5000
TRUTHSHIELD_DONATION_MONTHLY_GOAL=15000

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_QUEUE_CONNECTION=queue

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
TRUTHSHIELD_EMAIL_ENABLED=true
TRUTHSHIELD_EMAIL_PER_ADDRESS_HOUR=6
TRUTHSHIELD_EMAIL_PER_ADDRESS_DAY=24
TRUTHSHIELD_EMAIL_DUPLICATE_TTL_SECONDS=600

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OAuth providers. Leave blank until each provider is configured.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://truth-shield-api.otus.tw/api/auth/facebook/socialite-callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://truth-shield-api.otus.tw/api/auth/google/socialite-callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://truth-shield-api.otus.tw/api/auth/github/socialite-callback
