APP_NAME=TruthShield
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.truthshield.example

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=truth_shield
DB_USERNAME=truth_shield
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=database
SESSION_DRIVER=database

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=truthshield.example,www.truthshield.example
FRONTEND_URL=https://truthshield.example

TRUTHSHIELD_DEV_LOGIN_ENABLED=false
TRUTHSHIELD_STATUS_CACHE_STORE=redis
TRUTHSHIELD_STATUS_CACHE_VERSION=v1
TRUTHSHIELD_MIN_READ_SECONDS_BEFORE_VOTE=15
TRUTHSHIELD_EVIDENCE_REACTION_MIN_TRUST_SCORE=0.5
TRUTHSHIELD_LOW_TRUST_VOTE_CAP=0.25
TRUTHSHIELD_EVIDENCE_SNAPSHOT_MAX_BYTES=5242880
TRUTHSHIELD_EVIDENCE_SNAPSHOT_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp,image/gif,text/html,application/pdf,text/plain
TRUTHSHIELD_TRUSTED_EVIDENCE_HOSTS=imgur.com,www.imgur.com,i.imgur.com,archive.ph,web.archive.org
TRUTHSHIELD_ADMIN_EMAILS=admin@truthshield.example

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://api.truthshield.example/api/auth/facebook/socialite-callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.truthshield.example/api/auth/google/socialite-callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.truthshield.example/api/auth/github/socialite-callback

ECPAY_CHECKOUT_URL=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_TRADE_PREFIX=TSD
ECPAY_API_BASE_URL=https://api.truthshield.example
ECPAY_WEB_BASE_URL=https://truthshield.example
