APP_NAME=TruthShield
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://truth-shield-api.otus.tw
APP_FORCE_HTTPS=true

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=truth_shield
DB_USERNAME=truth_shield
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_ENCRYPT=true

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_QUEUE_CONNECTION=queue

SANCTUM_STATEFUL_DOMAINS=truth-shield.otus.tw,www.truth-shield.otus.tw
FRONTEND_URL=https://truth-shield.otus.tw

TRUTHSHIELD_DEV_LOGIN_ENABLED=false
TRUTHSHIELD_STATUS_CACHE_STORE=redis
TRUTHSHIELD_STATUS_CACHE_VERSION=v1
TRUTHSHIELD_MIN_READ_SECONDS_BEFORE_VOTE=15
TRUTHSHIELD_EVIDENCE_REACTION_MIN_TRUST_SCORE=0.5
TRUTHSHIELD_LOW_TRUST_VOTE_CAP=0.25
TRUTHSHIELD_EVIDENCE_SNAPSHOT_MAX_BYTES=5242880
TRUTHSHIELD_EVIDENCE_SNAPSHOT_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp,image/gif,text/html,application/pdf,text/plain
TRUTHSHIELD_TRUSTED_EVIDENCE_HOSTS=imgur.com,www.imgur.com,i.imgur.com,archive.ph,web.archive.org
TRUTHSHIELD_ADMIN_EMAILS=admin@truth-shield.otus.tw

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://truth-shield-api.otus.tw/api/auth/facebook/socialite-callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://truth-shield-api.otus.tw/api/auth/google/socialite-callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://truth-shield-api.otus.tw/api/auth/github/socialite-callback

ECPAY_CHECKOUT_URL=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_TRADE_PREFIX=TSD
ECPAY_API_BASE_URL=https://truth-shield-api.otus.tw
ECPAY_WEB_BASE_URL=https://truth-shield.otus.tw
TRUTHSHIELD_DONATION_AMOUNTS=100,300,500,1000,2000,5000
TRUTHSHIELD_DONATION_MONTHLY_GOAL=15000
